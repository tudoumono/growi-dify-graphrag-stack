# GraphRAG 専用 Elasticsearch
GRAPHRAG_ES_PASSWORD=graphrag

# Neo4j
NEO4J_PASSWORD=dify-graphrag

# プロバイダー切り替え: bedrock / ollama / gemini
EMBED_PROVIDER=bedrock
LLM_PROVIDER=bedrock

# Google Gemini（EMBED_PROVIDER=gemini または LLM_PROVIDER=gemini の場合に必須）
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_LLM_MODEL=gemini-2.0-flash-001

# AWS Bedrock
AWS_PROFILE=sandbox
AWS_REGION=us-east-1
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3
EMBED_DIMS=768

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# 一時ドキュメントの TTL（時間）。/ingest-temp で取り込んだドキュメントの有効期限
TEMP_DOC_TTL_HOURS=24

# Growi 連携（POST /ingest-growi を使う場合に必須）
GROWI_URL=http://localhost:3300
GROWI_API_KEY=
